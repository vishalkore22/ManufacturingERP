@model Manufacturing_Core.Entity.TrInventoryTransaction

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {

        $('#FkMatId').change(function () {

            var matId = $(this).val();

            if (!matId) {
                $('#Qty').val('');
                return;
            }

            $.ajax({
                url: '/User/TrInventoryTransactions/GetMaterialQty',
                type: 'GET',
                data: { fkMatId: matId },
                success: function (data) {
                    $('#Qty').val(data.qty);
                },
                error: function () {
                    alert('Unable to load quantity');
                }
            });
        });

    });
</script>



<div class="row">
    <form asp-action="Edit">
        <div class="form-group">
            <div class="col-sm-12 col-md-12 col-lg">
                <div class="card">
                    <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">Edit Tr Inventory</div>
                    <div class="card-body">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <input type="hidden" asp-for="PkInTransId" />
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg">
                                <div class="form-group">
                                    <label class="control-label" style="font-family:Verdana; font-weight:normal">Inventory Sr.No.</label>
                                    @Html.TextBox("Inventory Sr.No.", Model.PkInTransId, new { @class = "form-control", @readonly = "readonly" })
                                    <span asp-validation-for="PkInTransId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-3 col-md-3 col-lg">
                                <div class="form-group">
                                    <label asp-for="FkMatId" class="control-label">Material Name</label>
                                    <select asp-for="FkMatId" class="form-control" asp-items="ViewBag.FkMatId" id="FkMatId"></select>
                                </div>
                            </div>
                            <div class="col-sm-3 col-md-3 col-lg">
                                <div class="form-group">
                                    <label asp-for="TransType" class="control-label"></label>
                                    <input asp-for="TransType" class="form-control" />
                                    <span asp-validation-for="TransType" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label asp-for="FkWarehouseId" class="control-label"></label>
                                    <select asp-for="FkWarehouseId" class="form-control">
                                        <option value="select">--select warehouse--</option>
                                        <option value="1">p-1</option>
                                        <option value="2">p-2</option>
                                    </select>
                                    <span asp-validation-for="FkWarehouseId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label asp-for="Qty" class="control-label"></label>
                                    <input asp-for="Qty" id="Qty" name="Qty" class="form-control" />
                                    <span asp-validation-for="Qty" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label asp-for="TransDate" class="control-label"></label>
                                    <input asp-for="TransDate" class="form-control" />
                                    <span asp-validation-for="TransDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label asp-for="LocationId" class="control-label"></label>
                                    <select asp-for="LocationId" class="form-control">
                                        <option value="Select">--Select--</option>
                                        <option value="1">Pune</option>
                                        <option value="2">Mumbai</option>
                                    </Select>
                                    <span asp-validation-for="LocationId" class="text-danger"></span>
                                </div>
                            </div>                            
                        </div>                        
                        <div class="form-group">
                            <input type="submit" value="Update" class="btn btn-primary" />
                            <input type="button" value="Cancel" class="btn btn-primary" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>