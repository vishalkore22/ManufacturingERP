@model IEnumerable<Manufacturing_Core.Entity.TrInventoryTransaction>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}

@{
    ViewBag.Message = TempData["Action"];
}
<div class="row container">
    <div class="form-group">
        <div class="card">
            <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">View Tr Inventory </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        @if (ViewBag.Message == "Create")
                        {
                            <div class="alert alert-success">
                                <strong>@TempData["AlertMessage"]</strong>
                                <button type="button" class="close" data-dismiss="alert">
                                    <span>&times;</span>
                                </button>
                            </div>
                        }
                        else if (ViewBag.Message == "Edit")
                        {
                            <div class="alert alert-info">
                                <strong>@TempData["AlertMessage"]</strong>
                                <button type="button" class="close" data-dismiss="alert">
                                    <span>&times;</span>
                                </button>
                            </div>
                        }
                        else if (ViewBag.Message == "Delete")
                        {
                            <div class="alert alert-danger">
                                <strong>@TempData["AlertMessage"]</strong>
                                <button type="button" class="close" data-dismiss="alert">
                                    <span>&times;</span>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <p>
                            <a asp-action="Create">Create New</a>
                        </p>
                    </div>
                </div>
                <table class="table">
                    <thead>
                        <tr>
                            <th>
                                @Html.DisplayNameFor(model => model.PkInTransId)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.MatName)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.TransType)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.Warehouse)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.Qty)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.TransDate)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.Location)
                            </th>
                            
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.PkInTransId)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.MatName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.TransType)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Warehouse)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Qty)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.TransDate)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Location)
                                </td>                          
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.PkInTransId">Edit</a> |
                                    @* <a asp-action="Details" asp-route-id="@item.PkInTransId">Details</a> *@ |
                                    <a asp-action="Delete" asp-route-id="@item.PkInTransId">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


