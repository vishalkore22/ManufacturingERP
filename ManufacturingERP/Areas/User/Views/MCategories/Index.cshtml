@model Manufacturing_Core.ViewModels.MCategoryViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}
@{
    ViewBag.Message = TempData["Action"];
}

<div class="row container">
    <div class="form-group">
        <div class="col-sm-12 col-md-12 col-lg">
            <div class="card">
                <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">View Category</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12">
                            @if (ViewBag.Message == "Create")
                            {
                                <div class="alert alert-success">
                                    <strong>@TempData["AlertMessage"]</strong>
                                    <button type="button" class="close" data-dismiss="alert">
                                        <span>&times;</span>
                                    </button>
                                </div>
                            }
                            else if (ViewBag.Message == "Edit")
                            {
                                <div class="alert alert-info">
                                    <strong>@TempData["AlertMessage"]</strong>
                                    <button type="button" class="close" data-dismiss="alert">
                                        <span>&times;</span>
                                    </button>
                                </div>
                            }
                            else if (ViewBag.Message == "Delete")
                            {
                                <div class="alert alert-danger">
                                    <strong>@TempData["AlertMessage"]</strong>
                                    <button type="button" class="close" data-dismiss="alert">
                                        <span>&times;</span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group">
                        <p>
                            <a asp-action="Create">Create New</a>
                        </p>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>
                                    @Html.DisplayNameFor(model => model.mCategory.CategoryCode)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.mType.TypeName)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.mCategory.CategoryName)
                                </th>

                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null)
                            {
                                @foreach (var item in Model.ListMCategory)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.CategoryCode)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.TypeName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.CategoryName)
                                        </td>

                                        <td>
                                            <a asp-action="Edit" asp-route-id="@item.PkCatId">Edit</a> |
                                            <a asp-action="Details" asp-route-id="@item.PkCatId">Details</a> |
                                            <a asp-action="Delete" asp-route-id="@item.PkCatId">Delete</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>