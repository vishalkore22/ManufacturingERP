@model Manufacturing_Core.ViewModels.MCategoryViewModel

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <form asp-action="Delete">
        <div class="form-group">
            <div class="col-sm-12 col-md-12 col-lg">
                <div class="card">
                    <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">Delete Category Details</div>
                    <div class="card-body">
                        <h0>Are you sure you want to delete Category Details?</h0>
                        <input type="hidden" asp-for="mCategory.PkCatId" />
                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label class="control-label" for="AccountTypeId" style="font-family:Verdana; font-weight:normal">Category Id</label>
                                    @Html.TextBox("Category Id", Model.mCategory.PkCatId, new { @class = "form-control", @readonly = "readonly" })
                                    <span asp-validation-for="mCategory.PkCatId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label style="font-family:Verdana; font-weight:normal">Category Code</label>
                                    <input asp-for="mCategory.CategoryCode" class="form-control" />
                                    <span asp-validation-for="mCategory.CategoryCode" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label style="font-family:Verdana; font-weight:normal">Type Name</label>
                                    <select asp-for="mCategory.FkTypeId" class="form-control" asp-items="ViewBag.FkTypeId"></select>
                                    <span asp-validation-for="mCategory.FkTypeId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg">
                                <div class="form-group">
                                    <label style="font-family:Verdana; font-weight:normal">Category Name</label>
                                    <input asp-for="mCategory.CategoryName" class="form-control" />
                                    <span asp-validation-for="mCategory.CategoryName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-8 col-md-8 col-lg">
                                <div class="form-group">
                                    <label style="font-family:Verdana; font-weight:normal">Category Description</label>
                                    <input asp-for="mCategory.CategoryDescription" class="form-control" />
                                    <span asp-validation-for="mCategory.CategoryDescription" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <input type="submit" value="Delete" class="btn btn-primary" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
