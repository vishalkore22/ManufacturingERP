@model Manufacturing_Core.Entity.TrRequirementCollection

@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<style>
    #editor {
        min-height: 300px;
        border: 1px solid #ced4da;
        border-radius: 5px;
        padding: 15px;
        overflow-y: auto;
    }
</style>

<script>
    function format(command) {
      document.execCommand(command, false, null);
    }

    function clearEditor() {
      document.getElementById('editor').innerHTML = "";
    }

    function copyText() {
      const editor = document.getElementById("editor");
      navigator.clipboard.writeText(editor.innerText);
      alert("Text copied to clipboard!");
    }
</script>
<div class="row">
    <div class="col-md-12">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="card">
                <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">Create Requirement collection</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 col-sm-6 col-lg">
                            <div class="form-group">
                                <div class="form-group">
                                    <label asp-for="JobId" class="control-label"></label>
                                    <input asp-for="JobId" class="form-control" />
                                    <span asp-validation-for="JobId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="DepartmentId" class="control-label"></label>
                                <input asp-for="DepartmentId" class="form-control" />
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="DepartmentName" class="control-label"></label>
                                <input asp-for="DepartmentName" class="form-control" />
                                <span asp-validation-for="DepartmentName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="Designation" class="control-label"></label>
                                <input asp-for="Designation" class="form-control" />
                                <span asp-validation-for="Designation" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="NumberOfEmployeesRequired" class="control-label"></label>
                                <input asp-for="NumberOfEmployeesRequired" class="form-control" />
                                <span asp-validation-for="NumberOfEmployeesRequired" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="SelectionCriteria" class="control-label"></label>
                                <input asp-for="SelectionCriteria" class="form-control" />
                                <span asp-validation-for="SelectionCriteria" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="ExperienceRequired" class="control-label"></label>
                                <input asp-for="ExperienceRequired" class="form-control" />
                                <span asp-validation-for="ExperienceRequired" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="SkillsRequired" class="control-label"></label>
                                <input asp-for="SkillsRequired" class="form-control" />
                                <span asp-validation-for="SkillsRequired" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-4">
                            <div class="form-group">
                                <label asp-for="JobDescription1" class="control-label"></label>
                                <textarea name="Content" id="editor"></textarea>
                                <span asp-validation-for="JobDescription1" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 col-sm-12">
                            <div class="form-group">


                                <div class="container mt-5">
                                    <div class="card shadow">
                                        <div class="card-header bg-primary text-white">
                                            <h5 class="mb-0">Online Text Editor</h5>
                                        </div>

                                        <div class="card-body">

                                            <!-- Toolbar -->
                                            <div class="btn-toolbar mb-3">
                                                <div class="btn-group me-2">
                                                    <button class="btn btn-outline-secondary" onclick="format('bold')"><b>B</b></button>
                                                    <button class="btn btn-outline-secondary" onclick="format('italic')"><i>I</i></button>
                                                    <button class="btn btn-outline-secondary" onclick="format('underline')"><u>U</u></button>
                                                </div>

                                                <div class="btn-group me-2">
                                                    <button class="btn btn-outline-secondary" onclick="format('insertUnorderedList')">• List</button>
                                                    <button class="btn btn-outline-secondary" onclick="format('insertOrderedList')">1. List</button>
                                                </div>

                                                <div class="btn-group">
                                                    <button class="btn btn-danger" onclick="clearEditor()">Clear</button>
                                                    <button class="btn btn-success" onclick="copyText()">Copy</button>
                                                </div>
                                            </div>

                                            <!-- Editable Area -->
                                            @* <div id="editor" contenteditable="true" class="form-control">
                                                
                                            </div> *@
                                            @* <input accept="$0" asp-for="JobDescription" contenteditable="true" class="form-control" id="editor"/> *@
                                            <label asp-for="JobDescription" class="form-label"></label>
                                            <textarea accept="$0" asp-for="JobDescription" contenteditable="true" class="form-control" id="editor"></textarea>
                                            <span asp-validation-for="JobDescription" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-4">
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="Save" class="btn btn-primary" />
                        <input type="submit" value="Cancel" class="btn btn-primary" />
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>

