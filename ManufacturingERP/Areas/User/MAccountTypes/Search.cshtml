@model IEnumerable<Manufacturing_Core.Entity.MAccountType>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}
@{
    ViewBag.Message = @TempData["Action"];
}
<div class="row container">
    <div class="form-group">
        <div class="col-sm-12 col-md-12 col-lg">
            <div class="card">
                <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">View Account Type</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12">
                            @if (ViewBag.Message == "Create")
                            {
                                <div class="alert alert-success">
                                    <strong>@TempData["AlertMessage"]</strong>
                                    <button type="button" class="close" data-dismiss="alert">
                                        <span>&times;</span>
                                    </button>
                                </div>
                            }
                            else if (ViewBag.Message == "Edit")
                            {
                                <div class="alert alert-info">
                                    <strong>@TempData["AlertMessage"]</strong>
                                    <button type="button" class="close" data-dismiss="alert">
                                        <span>&times;</span>
                                    </button>
                                </div>
                            }
                            else if (ViewBag.Message == "Delete")
                            {
                                <div class="alert alert-danger">
                                    <strong>@TempData["AlertMessage"]</strong>
                                    <button type="button" class="close" data-dismiss="alert">
                                        <span>&times;</span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="form-group">
                                    <p>
                                        <a asp-action="Create">Create New</a>
                                    </p>
                                </div>
                                <div class="form-group">
                                    <div class="row">
                                        @using (Html.BeginForm("Search", "MAccountTypes", FormMethod.Get))
                                        {
                                            <div class="col-sm-5">
                                                <div class="row">
                                                    <div class="col-sm-10">
                                                        <b>Search By:</b>
                                                        @Html.RadioButton("SearchBy", "AccountType", true)<text>Account Type</text>
                                                        @Html.RadioButton("SearchBy", "AccountTypeId", true)<text>Account Type Id</text>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-4">
                                                @Html.TextBox("search", "", htmlAttributes: new { @class = " w-150 form-control" })
                                            </div>
                                            <div class="col-sm-1">
                                                <input type="submit" value="Search" class="btn btn-success" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                    <table class="table">
                        <thead>
                            <tr>
                                <th>
                                    @Html.DisplayNameFor(model => model.AccountTypeId)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.AccountType)
                                </th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.AccountTypeId)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.AccountType)
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.PkAccountTypeId">Edit</a> |
                                        <a asp-action="Details" asp-route-id="@item.PkAccountTypeId">Details</a> |
                                        <a asp-action="Delete" asp-route-id="@item.PkAccountTypeId">Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
