@model IEnumerable<Manufacturing_Core.Entity.MAccountType>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}
@* @model List<SalesData> *@

@{
    ViewData["Title"] = "Dashboard";
}

<h2>Sales Dashboard</h2>

<div>
    <!-- Table to display Sales Data -->
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.AccountTypeId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.AccountType)
                </th>                
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.AccountTypeId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.AccountType)
                    </td>                    
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Chart.js for visualizing data -->
<canvas id="salesChart" width="400" height="200"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Prepare the data for the chart
    var salesData = @Html.Raw(Json.Serialize(Model));

    var categories = salesData.map(function (item) { return item.category; });
    var sales = salesData.map(function (item) { return item.sales; });

    var ctx = document.getElementById('salesChart').getContext('2d');
    var salesChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: categories,
            datasets: [{
                label: 'Sales',
                data: sales,
                backgroundColor: 'rgba(54, 162, 235, 0.2)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 1
            }]
        },
        options: {
            scales: {
                y: {
                    beginAtZero: true
                }
            }
        }
    });
</script>


