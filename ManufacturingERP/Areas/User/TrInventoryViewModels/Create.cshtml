@model Manufacturing_Core.ViewModels.TrInventoryViewModel

@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <div class="col-md-12">        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="card">
                <div class="card-header text-white" style="width:80%; height:65px; background-color:orangered; margin-left:100px; margin-top:-30px;">Create Stock</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-4 col-md-4 col-lg">
                            <!-- Material -->
                            <div class="form-group">
                                <label>Material</label>
                                <select asp-for="MaterialId" class="form-control" asp-items="ViewBag.MaterialId"></select>
                            </div>
                        </div>
                        <div class="col-sm-4 col-md-4 col-lg">
                            <!-- Warehouse -->
                            <div class="form-group">
                                <label>Warehouse</label>
                                <select asp-for="WarehouseId" class="form-control" asp-items="ViewBag.WarehouseId"></select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4 col-md-4 col-lg">
                            <!-- Location -->
                            <div class="form-group">
                                <label>Location</label>
                                <select asp-for="LocationId" class="form-control" asp-items="ViewBag.LocationId"></select>
                            </div>
                        </div>
                        <div class="col-sm-4 col-md-4 col-lg">
                            <!-- Transaction Type -->
                            <div class="col-md-3">
                                <label>Transaction Type</label>
                                <select asp-for="TransactionType" class="form-control">
                                    <option value="1">Purchase (IN)</option>
                                    <option value="2">Sale (OUT)</option>
                                    <option value="3">Transfer</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4 col-md-4 col-lg">
                            <!-- Quantity -->
                            <div class="form-group">
                                <label>Quantity</label>
                                <input asp-for="Quantity" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="Create" class="btn btn-primary" />
                    </div>
                </div>
            </div>                      
        </form>
    </div>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>

